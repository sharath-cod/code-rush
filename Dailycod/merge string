#include <stdlib.h>
#include <string.h>

char *mergeAlternately(char *word1, char *word2)
{
    int len1 = strlen(word1);
    int len2 = strlen(word2);

    char *result = (char *)malloc(len1 + len2 + 1);

    int i = 0;
    int j = 0;
    int k = 0;

    while (i < len1 && j < len2)
    {
        result[k] = word1[i];
        k++;
        i++;

        result[k] = word2[j];
        k++;
        j++;
    }

    while (i < len1)
    {
        result[k] = word1[i];
        k++;
        i++;
    }

    while (j < len2)
    {
        result[k] = word2[j];
        k++;
        j++;
    }

    result[k] = '\0';

    return result;
}
